{
  "name": "mtproto-nodejs-client",
  "version": "8.0.1",
  "type": "module",
  "description": "Telegram API JS (MTProto) client library for Node.js",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsgo",
    "watch": "tsgo --watch",
    "test": "node --test lib/**/*.test.js",
    "sync-schema": "node lib/sync-schema.js",
    "generate": "node lib/generate.js"
  },
  "license": "GPL-3.0",
  "dependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20251210.1",
    "aes-js": "3.1.2",
    "big-integer": "1.6.52",
    "debug": "4.4.3",
    "leemon": "6.2.0",
    "lodash.debounce": "4.0.8",
    "pako": "2.1.0",
    "@types/aes-js": "^3.1.4",
    "@types/debug": "^4.1.12",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^24.10.2",
    "@types/pako": "^2.0.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fedyk/mtproto-nodejs-client.git"
  }
}